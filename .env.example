# Public origins and persistence
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ZAP_PUBLIC_ORIGIN=http://localhost:3000
ZAP_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_CONVEX_URL=
CONVEX_URL=
CONVEX_DEPLOYMENT=
ZAP_CONVEX_SERVICE_TOKEN=

# Optional thirdweb SIWE + Supabase session backbone
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
# Preferred server credential; the public client id is the verification fallback.
THIRDWEB_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
ZAP_WALLET_PROOF_FUNCTION=zap-wallet-proof
ZAP_SECRET_REVEAL_TOKEN=
ZAP_MANAGED_PROVIDER_SECRETS_FUNCTION=zap-managed-provider-secrets
USER_SECRETS_ENCRYPTION_KEY=
ZAP_SECRETS_ALLOWED_ORIGIN=http://localhost:3000

# Managed WZRD Cloud (server-only JSON bundle or Supabase Edge Function secrets)
WZRD_CLOUD_PROVIDER_KEYS=
WZRD_CLOUD_DAILY_CAP_USD=5

# LLM routing
ZAP_LLM_ROUTE=gateway
ZAP_LLM_MODEL=
ZAP_LLM_GATEWAY_MODEL=anthropic/claude-sonnet-4.6
ZAP_LLM_OPENAI_MODEL=gpt-5.2
ZAP_LLM_ANTHROPIC_MODEL=claude-sonnet-4.6
ZAP_LLM_OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
ZAP_JUDGE_MODEL=google/gemini-2.5-flash
ZAP_AURA_MODEL=google/gemini-3.5-flash
# Purpose- and route-specific overrides. Direct providers require native model ids.
ZAP_JUDGE_GATEWAY_MODEL=google/gemini-2.5-flash
ZAP_JUDGE_OPENAI_MODEL=gpt-5.4
ZAP_JUDGE_ANTHROPIC_MODEL=claude-sonnet-4-6
ZAP_JUDGE_OPENROUTER_MODEL=google/gemini-2.5-flash
ZAP_AURA_GATEWAY_MODEL=google/gemini-3.5-flash
ZAP_AURA_OPENAI_MODEL=gpt-5.4
ZAP_AURA_ANTHROPIC_MODEL=claude-sonnet-4-6
ZAP_AURA_OPENROUTER_MODEL=google/gemini-3.5-flash

# Opt-in Eve evals. Keep EVALS_LIVE=0 in CI; `npm run evals:live` sets it to 1.
EVALS_LIVE=0
EVALS_JUDGE_MODEL=google/gemini-2.5-flash
# Optional persisted output fixture for the live `judge_asset` rubric eval.
EVALS_LIVE_ASSET_ID=
EVALS_LIVE_RUN_ID=
EVALS_LIVE_STEP_ID=

# Sandbox selection: vercel | box | daytona | e2b | docker | auto
ZAP_SANDBOX_BACKEND=box
# Sprite presets emit these values; standalone deployments may override them.
ZAP_SANDBOX_CPU=2
ZAP_SANDBOX_MEMORY_MB=4096
ZAP_SANDBOX_TIMEOUT_SECONDS=900
BOX_API_KEY=
DAYTONA_API_KEY=
E2B_API_KEY=

# Chat channels and one-time wallet linking
REDIS_URL=
CHANNEL_LINK_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_TENANT_ID=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
IMESSAGE_BRIDGE_URL=
IMESSAGE_BRIDGE_TOKEN=

# Sprite alpha: Composio + scoped Vercel deployment
COMPOSIO_API_KEY=
SPRITE_VERCEL_TOKEN=
SPRITE_VERCEL_TEAM_ID=
SPRITE_VERCEL_GIT_REPO=owner/repository
SPRITE_VERCEL_GIT_REPO_ID=
SPRITE_VERCEL_GIT_REF=main
SPRITE_VERCEL_ROOT_DIRECTORY=
# Allowlisted plugin ids resolved to MCP endpoints; values may include headers.
SPRITE_PLUGIN_CATALOG_JSON={}

# Media provider BYOK keys
GMI_API_KEY=
# Required for the private Air iMessage service. Verify the current GMI
# Seedance Fast price before setting this value; production fails closed when
# it is absent or invalid. Example only: do not copy an unverified price.
GMI_SEEDANCE_FAST_USD_PER_SECOND=
FAL_KEY=
PRODIA_TOKEN=
RUNWARE_KEY=
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_API_KEY=
VERTEX_SERVICE_ACCOUNT_JSON=
VERTEX_OUTPUT_GCS_URI=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_S3_OUTPUT_URI=

# Runtime queues, artifacts, webhooks, and operations
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BLOB_READ_WRITE_TOKEN=
# Private Air → Zap service. This token must match Air's
# ZAP_AIR_SERVICE_TOKEN and must never be exposed to a browser.
ZAP_AIR_SERVICE_TOKEN=
# A distinct, stable 32+ byte secret used only to HMAC Air run IDs and
# redacted request digests. It may be rotated independently of bearer auth.
ZAP_AIR_IDEMPOTENCY_HMAC_SECRET=
# A distinct, stable 32+ byte secret used to encrypt short-lived GMI signed
# upload tickets in Redis. Never reuse this value as a bearer token.
ZAP_AIR_UPLOAD_TICKET_ENCRYPTION_KEY=
# Both caps are enforced before GMI work is submitted. Concurrency is bounded
# at two even if this value is configured higher.
ZAP_AIR_DAILY_CAP_USD=
ZAP_AIR_MAX_RUN_USD=
ZAP_AIR_CONCURRENCY_LIMIT=2
ZAP_AIR_MAX_OUTPUT_BYTES=26214400
# First-frame and generated GMI objects use GCS URLs by default.
GMI_UPLOAD_PUBLIC_HOST_ALLOWLIST=storage.googleapis.com
# Signed PUT URLs returned by GMI are independently constrained before Air
# receives them. Set only verified GMI object-storage hosts.
GMI_UPLOAD_PUT_HOST_ALLOWLIST=storage.googleapis.com
ZAP_POLL_DRAIN_URL=http://localhost:3000/api/providers/poll/drain
ZAP_POLL_DRAIN_SECRET=
ZAP_PROVIDER_WEBHOOK_SECRET=
ZAP_PUBLISH_TOKEN=
ZAP_AGENT_TOKEN=
ZAP_OUTPUT_HOST_ALLOWLIST=storage.googleapis.com,fal.media,fal.run,gmicloud.ai,runware.ai,prodia.com,vercel-storage.com,public.blob.vercel-storage.com
ZAP_SYNC_POLL_INTERVAL_MS=5000
ZAP_SYNC_POLL_TIMEOUT_MS=1200000

# Optional execution spike; Vercel remains the v0.3.0 production default
ZAP_EXECUTION_MODE=vercel
