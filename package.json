{
  "name": "zap-platform",
  "version": "0.2.0",
  "private": true,
  "description": "Zap: one-click generative content recipes on Eve, Next.js, Convex, Upstash, GMI Cloud, and fal.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "next build",
    "cli": "node packages/cli/bin/zap.js",
    "dev": "next dev",
    "docs:dev": "npm --prefix docs install --no-audit --no-fund && npm --prefix docs run dev",
    "docs:links": "npm --prefix docs install --no-audit --no-fund && npm --prefix docs run links",
    "docs:validate": "npm --prefix docs install --no-audit --no-fund && npm --prefix docs run validate",
    "doctor": "node packages/cli/bin/zap.js doctor",
    "start": "next start",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:cli": "node packages/cli/bin/zap.js validate agent/skills/zap-world-cup-entrance/Zap.md && node packages/cli/bin/zap.js run agent/skills/zap-world-cup-entrance/Zap.md --json",
    "eve:info": "eve info",
    "eve:build": "eve build",
    "convex:codegen": "convex codegen"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.72",
    "@fal-ai/client": "^1.8.0",
    "@radix-ui/react-use-controllable-state": "1.2.2",
    "@shikijs/core": "4.1.0",
    "@shikijs/engine-javascript": "4.1.0",
    "@shikijs/engine-oniguruma": "4.1.0",
    "@streamdown/cjk": "1.0.3",
    "@streamdown/code": "1.1.1",
    "@streamdown/math": "1.0.2",
    "@streamdown/mermaid": "1.0.2",
    "@tailwindcss/postcss": "4.3.0",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "2.5.0",
    "@vercel/connect": "0.2.2",
    "ai": "7.0.0-beta.178",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "convex": "^1.28.0",
    "eve": "0.15.1",
    "lucide-react": "1.16.0",
    "motion": "12.40.0",
    "nanoid": "5.1.11",
    "next": "16.2.6",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shiki": "4.1.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "use-stick-to-bottom": "1.1.4",
    "yaml": "^2.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "microsandbox": "^0.5.7",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "resolutions": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": "24.x"
  }
}
