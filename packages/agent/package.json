{
  "name": "@wzrdtech/agent",
  "version": "0.3.0",
  "private": false,
  "description": "Agent prompts and helper utilities for authoring and running Zap recipes.",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-dts-imports.mjs dist",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gratitude5dee/Zap.git",
    "directory": "packages/agent"
  },
  "bugs": {
    "url": "https://github.com/gratitude5dee/Zap/issues"
  },
  "homepage": "https://zap.wzrd.tech",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./instructions": {
      "types": "./dist/instructions.d.ts",
      "import": "./dist/instructions.js"
    }
  },
  "dependencies": {
    "@wzrdtech/core": "0.3.0"
  },
  "engines": {
    "node": "24.x"
  }
}
