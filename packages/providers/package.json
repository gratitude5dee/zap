{
  "name": "@wzrdtech/providers",
  "version": "0.3.0",
  "private": false,
  "description": "Provider adapters and queue helpers for Zap runtimes.",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-dts-imports.mjs dist",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gratitude5dee/Zap.git",
    "directory": "packages/providers"
  },
  "bugs": {
    "url": "https://github.com/gratitude5dee/Zap/issues"
  },
    "homepage": "https://zap.wzrd.tech",
    "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./aws": {
      "types": "./dist/aws.d.ts",
      "import": "./dist/aws.js"
    },
    "./vertex": {
      "types": "./dist/vertex.d.ts",
      "import": "./dist/vertex.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./fal": {
      "types": "./dist/fal.d.ts",
      "import": "./dist/fal.js"
    },
    "./gmi": {
      "types": "./dist/gmi.d.ts",
      "import": "./dist/gmi.js"
    },
    "./poll-queue": {
      "types": "./dist/poll-queue.d.ts",
      "import": "./dist/poll-queue.js"
    },
    "./pricing": {
      "types": "./dist/pricing.d.ts",
      "import": "./dist/pricing.js"
    },
    "./prodia": {
      "types": "./dist/prodia.d.ts",
      "import": "./dist/prodia.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./runware": {
      "types": "./dist/runware.d.ts",
      "import": "./dist/runware.js"
    }
  },
  "dependencies": {
    "@fal-ai/client": "^1.8.0",
    "@upstash/redis": "^1.38.0",
    "@wzrdtech/core": "0.3.0"
  },
  "engines": {
    "node": "24.x"
  }
}
